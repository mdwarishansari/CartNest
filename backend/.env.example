# ============================================
# CartNest Backend — Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
# ============================================

# ---- Server ----
NODE_ENV=development
PORT=5000

# ---- MongoDB Atlas ----
# Get from: https://cloud.mongodb.com → Connect → Connection String
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/cartnest?retryWrites=true&w=majority

# ---- JWT ----
# Any random string for signing tokens (use: openssl rand -hex 32)
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# ---- Firebase Admin SDK ----
# Get from: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
# Copy the values from the downloaded JSON file
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ---- Firebase Client Config (used by frontend, listed here for reference) ----
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com

# ---- Cloudinary ----
# Get from: https://console.cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# Optional: If using unsigned presets
# CLOUDINARY_UPLOAD_PRESET=your_preset

# ---- Razorpay ----
# Get from: https://dashboard.razorpay.com → Settings → API Keys
# Use TEST keys for development
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ---- Redis ----
# For local: redis://localhost:6379
# For managed (Upstash/Redis Labs): redis://<username>:<password>@<host>:<port>
REDIS_URL=redis://localhost:6379

# ---- SMTP (Email) ----
# Option 1: Gmail (development / small scale)
#   - Enable 2FA on your Google Account
#   - Go to: https://myaccount.google.com/apppasswords
#   - Generate an App Password and use it as SMTP_PASS
# Option 2: SendGrid / Mailgun (production recommended)
#   - Use the SMTP credentials from your provider
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
# If using Gmail with 2FA enabled, generate an App Password:
#   1. Go to https://myaccount.google.com/apppasswords
#   2. Select "Mail" and your device
#   3. Copy the 16-character password and paste below
SMTP_PASS=your_google_app_password_here

# ---- Frontend URL (for CORS) ----
FRONTEND_URL=http://localhost:5173

# ---- Backend URL ----
BACKEND_URL=http://localhost:5000

# ---- Admin Seed ----
# On first server start, if no admin exists, one will be created with these credentials.
# IMPORTANT: Change or remove these in production after seeding.
ADMIN_SEED_EMAIL=admin@cartnest.com
ADMIN_SEED_NAME=CartNest Admin

# ---- Site Info ----
SITE_NAME=CartNest
SITE_DESCRIPTION=A lightweight multi-vendor marketplace for small sellers.
